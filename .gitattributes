# Normalize line endings in the repo to LF so shell/python scripts work for
# recipients on macOS/Linux regardless of the maintainer's Windows checkout.
* text=auto eol=lf

# Scripts must stay LF even on Windows checkouts.
*.sh    text eol=lf
*.py    text eol=lf
*.mjs   text eol=lf

# Windows-only scripts may keep CRLF.
*.ps1   text eol=crlf
*.bat   text eol=crlf

# Binary artifacts — never touch line endings.
*.zip   binary
*.png   binary
*.jpg   binary
*.ico   binary
*.pdf   binary
